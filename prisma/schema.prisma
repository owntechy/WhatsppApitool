generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String?
  fullName      String?
  image         String?
  role              String    @default("user")
  betaFeatures      String?   @map("beta_features")
  twoFactorEnabled  Boolean   @default(true) @map("two_factor_enabled")
  status            String    @default("active")

  accounts          Account[]
  sessions          Session[]
  profiles          Profile[]
  contacts          Contact[]
  tags              Tag[]
  customFields      CustomField[]
  contactNotes      ContactNote[]
  conversations     Conversation[]
  whatsappConfigs   WhatsAppConfig[]
  messageTemplates  MessageTemplate[]
  pipelines         Pipeline[]
  deals             Deal[]
  broadcasts        Broadcast[]
  automations       Automation[]
  automationLogs    AutomationLog[]
  flows             Flow[]
  flowRuns          FlowRun[]
  verificationCodes VerificationCode[]

  @@map("users")
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  fullName  String   @map("full_name")
  email     String
  avatarUrl String?  @map("avatar_url")
  role      String   @default("user")
  betaFeatures String? @map("beta_features")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedDeals Deal[]

  @@unique([userId])
  @@map("profiles")
}

model Contact {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  phone     String
  name      String?
  email     String?
  company   String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactTags       ContactTag[]
  contactCustomValues ContactCustomValue[]
  contactNotes      ContactNote[]
  conversations     Conversation[]
  deals             Deal[]
  broadcastRecipients BroadcastRecipient[]
  automationLogs    AutomationLog[]
  flowRuns          FlowRun[]

  @@index([userId])
  @@index([phone])
  @@map("contacts")
}

model Tag {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  color     String   @default("#3b82f6")
  createdAt DateTime @default(now()) @map("created_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactTags ContactTag[]

  @@index([userId])
  @@map("tags")
}

model ContactTag {
  id        String   @id @default(cuid())
  contactId String   @map("contact_id")
  tagId     String   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@index([contactId])
  @@index([tagId])
  @@map("contact_tags")
}

model CustomField {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  fieldName   String   @map("field_name")
  fieldType   String   @default("text") @map("field_type")
  fieldOptions Json?   @map("field_options")
  createdAt   DateTime @default(now()) @map("created_at")

  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactCustomValues ContactCustomValue[]

  @@index([userId])
  @@map("custom_fields")
}

model ContactCustomValue {
  id            String @id @default(cuid())
  contactId     String @map("contact_id")
  customFieldId String @map("custom_field_id")
  value         String?

  contact     Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  customField CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([contactId, customFieldId])
  @@map("contact_custom_values")
}

model ContactNote {
  id        String   @id @default(cuid())
  contactId String   @map("contact_id")
  userId    String   @map("user_id")
  noteText  String   @map("note_text")
  createdAt DateTime @default(now()) @map("created_at")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@map("contact_notes")
}

model Conversation {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  contactId       String   @map("contact_id")
  status          String   @default("open")
  assignedAgentId String?  @map("assigned_agent_id")
  lastMessageText String?  @map("last_message_text")
  lastMessageAt   DateTime? @map("last_message_at")
  unreadCount     Int      @default(0) @map("unread_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact         Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages        Message[]
  messageReactions MessageReaction[]
  deals           Deal[]
  flowRuns        FlowRun[]

  @@index([userId])
  @@index([contactId])
  @@map("conversations")
}

model Message {
  id                String   @id @default(cuid())
  conversationId    String   @map("conversation_id")
  senderType        String   @map("sender_type")
  senderId          String?  @map("sender_id")
  contentType       String   @default("text") @map("content_type")
  contentText       String?  @map("content_text")
  mediaUrl          String?  @map("media_url")
  templateName      String?  @map("template_name")
  messageId         String?  @map("message_id")
  status            String   @default("sent")
  createdAt         DateTime @default(now()) @map("created_at")
  replyToMessageId  String?  @map("reply_to_message_id")
  interactiveReplyId String? @map("interactive_reply_id")

  conversation  Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  reactions     MessageReaction[]
  flowRuns      FlowRun[]        @relation("lastPromptMessage")
  replyTo       Message?         @relation("MessageReply", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies       Message[]        @relation("MessageReply")

  @@index([conversationId])
  @@index([messageId])
  @@index([replyToMessageId])
  @@map("messages")
}

model MessageReaction {
  id             String   @id @default(cuid())
  messageId      String   @map("message_id")
  conversationId String   @map("conversation_id")
  actorType      String   @map("actor_type")
  actorId        String?  @map("actor_id")
  emoji          String
  createdAt      DateTime @default(now()) @map("created_at")

  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([messageId, actorType, actorId])
  @@index([conversationId])
  @@index([messageId])
  @@map("message_reactions")
}

model WhatsAppConfig {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  phoneNumberId  String   @map("phone_number_id")
  wabaId         String?  @map("waba_id")
  accessToken    String   @db.Text @map("access_token")
  verifyToken    String?  @db.Text @map("verify_token")
  status         String   @default("disconnected")
  connectedAt    DateTime? @map("connected_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([phoneNumberId])
  @@map("whatsapp_config")
}

model MessageTemplate {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  name           String
  category       String   @default("Marketing")
  language       String?  @default("en_US")
  headerType     String?  @map("header_type")
  headerContent  String?  @map("header_content")
  bodyText       String   @map("body_text")
  footerText     String?  @map("footer_text")
  buttons        Json?
  status         String?  @default("Draft")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("message_templates")
}

model Pipeline {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  stages PipelineStage[]
  deals  Deal[]

  @@index([userId])
  @@map("pipelines")
}

model PipelineStage {
  id         String   @id @default(cuid())
  pipelineId String   @map("pipeline_id")
  name       String
  position   Int      @default(0)
  color      String   @default("#3b82f6")
  createdAt  DateTime @default(now()) @map("created_at")

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@index([pipelineId])
  @@map("pipeline_stages")
}

model Deal {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  pipelineId        String   @map("pipeline_id")
  stageId           String   @map("stage_id")
  contactId         String?  @map("contact_id")
  conversationId    String?  @map("conversation_id")
  assignedTo        String?  @map("assigned_to")
  title             String
  value             Decimal  @default(0) @db.Decimal(12, 2)
  currency          String   @default("USD")
  notes             String?
  expectedCloseDate DateTime? @map("expected_close_date")
  status            String   @default("open")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  pipeline     Pipeline     @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage        PipelineStage @relation(fields: [stageId], references: [id])
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  conversation Conversation? @relation(fields: [conversationId], references: [id])
  assignee     Profile?     @relation(fields: [assignedTo], references: [userId])

  @@index([pipelineId])
  @@index([stageId])
  @@index([userId])
  @@map("deals")
}

model Broadcast {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  name              String
  templateName      String   @map("template_name")
  templateLanguage  String   @default("en_US") @map("template_language")
  templateVariables Json?    @map("template_variables")
  audienceFilter    Json?    @map("audience_filter")
  scheduledAt       DateTime? @map("scheduled_at")
  status            String   @default("draft")
  totalRecipients   Int      @default(0) @map("total_recipients")
  sentCount         Int      @default(0) @map("sent_count")
  deliveredCount    Int      @default(0) @map("delivered_count")
  readCount         Int      @default(0) @map("read_count")
  repliedCount      Int      @default(0) @map("replied_count")
  failedCount       Int      @default(0) @map("failed_count")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipients  BroadcastRecipient[]

  @@index([userId])
  @@map("broadcasts")
}

model BroadcastRecipient {
  id                String    @id @default(cuid())
  broadcastId       String    @map("broadcast_id")
  contactId         String?   @map("contact_id")
  status            String    @default("pending")
  sentAt            DateTime? @map("sent_at")
  deliveredAt       DateTime? @map("delivered_at")
  readAt            DateTime? @map("read_at")
  repliedAt         DateTime? @map("replied_at")
  errorMessage      String?   @map("error_message")
  whatsappMessageId String?   @map("whatsapp_message_id")
  createdAt         DateTime  @default(now()) @map("created_at")

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  contact   Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([broadcastId])
  @@index([broadcastId, status])
  @@unique([whatsappMessageId])
  @@map("broadcast_recipients")
}

model Automation {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  name           String
  description    String?
  triggerType    String   @map("trigger_type")
  triggerConfig  Json     @default("{}") @map("trigger_config")
  isActive       Boolean  @default(false) @map("is_active")
  executionCount Int      @default(0) @map("execution_count")
  lastExecutedAt DateTime? @map("last_executed_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user                User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps               AutomationStep[]
  logs                AutomationLog[]

  @@index([userId])
  @@index([triggerType])
  @@map("automations")
}

model AutomationStep {
  id            String  @id @default(cuid())
  automationId  String  @map("automation_id")
  parentStepId  String? @map("parent_step_id")
  branch        String?
  stepType      String  @map("step_type")
  stepConfig    Json    @default("{}") @map("step_config")
  position      Int
  createdAt     DateTime @default(now()) @map("created_at")

  automation       Automation           @relation(fields: [automationId], references: [id], onDelete: Cascade)
  parentStep       AutomationStep?      @relation("AutomationStepParent", fields: [parentStepId], references: [id], onDelete: Cascade)
  childSteps       AutomationStep[]     @relation("AutomationStepParent")

  @@index([automationId, position])
  @@index([parentStepId])
  @@map("automation_steps")
}

model AutomationLog {
  id            String   @id @default(cuid())
  automationId  String   @map("automation_id")
  userId        String   @map("user_id")
  contactId     String?  @map("contact_id")
  triggerEvent  String   @map("trigger_event")
  stepsExecuted Json     @default("[]") @map("steps_executed")
  status        String
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")

  automation     Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact        Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([automationId, createdAt])
  @@index([userId])
  @@map("automation_logs")
}

model AutomationPendingExecution {
  id              String   @id @default(cuid())
  automationId    String   @map("automation_id")
  userId          String   @map("user_id")
  contactId       String?  @map("contact_id")
  logId           String?  @map("log_id")
  parentStepId    String?  @map("parent_step_id")
  branch          String?
  nextStepPosition Int     @map("next_step_position")
  context         Json     @default("{}")
  status          String   @default("pending")
  runAt           DateTime @map("run_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([runAt])
  @@map("automation_pending_executions")
}

model Flow {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  name            String
  description     String?
  status          String   @default("draft")
  triggerType     String   @map("trigger_type")
  triggerConfig   Json     @default("{}") @map("trigger_config")
  entryNodeId     String?  @map("entry_node_id")
  fallbackPolicy  Json     @default("{\"on_unknown_reply\":\"reprompt\",\"max_reprompts\":2,\"on_timeout_hours\":24,\"on_exhaust\":\"handoff\"}") @map("fallback_policy")
  executionCount  Int      @default(0) @map("execution_count")
  lastExecutedAt  DateTime? @map("last_executed_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  nodes FlowNode[]
  runs  FlowRun[]

  @@index([userId, triggerType])
  @@map("flows")
}

model FlowNode {
  id        String   @id @default(cuid())
  flowId    String   @map("flow_id")
  nodeKey   String   @map("node_key")
  nodeType  String   @map("node_type")
  config    Json     @default("{}")
  positionX Int      @default(0) @map("position_x")
  positionY Int      @default(0) @map("position_y")
  createdAt DateTime @default(now()) @map("created_at")

  flow Flow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@unique([flowId, nodeKey])
  @@index([flowId])
  @@map("flow_nodes")
}

model FlowRun {
  id                    String   @id @default(cuid())
  flowId                String   @map("flow_id")
  userId                String   @map("user_id")
  contactId             String?  @map("contact_id")
  conversationId        String?  @map("conversation_id")
  status                String   @default("active")
  currentNodeKey        String?  @map("current_node_key")
  lastPromptMessageId   String?  @map("last_prompt_message_id")
  vars                  Json     @default("{}")
  repromptCount         Int      @default(0) @map("reprompt_count")
  startedAt             DateTime @default(now()) @map("started_at")
  lastAdvancedAt        DateTime @default(now()) @map("last_advanced_at")
  endedAt               DateTime? @map("ended_at")
  endReason             String?  @map("end_reason")

  flow         Flow            @relation(fields: [flowId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact      Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  conversation Conversation?   @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  lastPrompt   Message?        @relation("lastPromptMessage", fields: [lastPromptMessageId], references: [id], onDelete: SetNull)
  events       FlowRunEvent[]

  @@index([flowId, startedAt])
  @@index([userId, contactId])
  @@map("flow_runs")
}

model VerificationCode {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  code          String
  type          String    @default("2fa")
  signInToken   String?   @map("sign_in_token")
  expiresAt     DateTime  @map("expires_at")
  consumedAt    DateTime? @map("consumed_at")
  signedInAt    DateTime? @map("signed_in_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([code])
  @@index([signInToken])
  @@map("verification_codes")
}

model FlowRunEvent {
  id        String   @id @default(cuid())
  flowRunId String   @map("flow_run_id")
  eventType String   @map("event_type")
  nodeKey   String?  @map("node_key")
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  flowRun FlowRun @relation(fields: [flowRunId], references: [id], onDelete: Cascade)

  @@index([flowRunId, eventType])
  @@index([flowRunId, createdAt])
  @@map("flow_run_events")
}
